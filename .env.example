# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to GitHub — it contains secret keys.

# ── AI Studio ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=
APP_URL=

# ── Supabase / Prisma (get these from Supabase Project Settings → Database) ──
# Use the "Transaction" pooler connection string for DATABASE_URL (port 6543)
# Use the direct connection string for DIRECT_URL (port 5432)
DATABASE_URL=
DIRECT_URL=

# ── Resend (get this from resend.com → API Keys) ──────────────────────────────
# Used server-side to send login emails. NEVER prefix with VITE_ — keep it secret.
RESEND_API_KEY=

# ── Supabase Auth (get these from Supabase Project Settings → API) ─────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SITE_URL=

# ── Optional ──────────────────────────────────────────────────────────────────
# The "from" address for login emails.
# Default: onboarding@resend.dev  (testing only — see deployment guide)
# RESEND_FROM_EMAIL=SpaceX HQ <noreply@yourdomain.com>

# The name shown in login emails.
# Default: SpaceX HQ
# APP_NAME=SpaceX HQ
